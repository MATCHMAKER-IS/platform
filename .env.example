# 全アプリ共通の環境変数テンプレート。
# packages/env が起動時に zod で検証し、必須値が無ければ即起動失敗する。
NODE_ENV=development
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# メール(mail パッケージ)
MAIL_TRANSPORT=smtp          # smtp | resend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.co.jp
RESEND_API_KEY=

# ログ(logger パッケージ)
LOG_LEVEL=info               # trace|debug|info|warn|error|fatal

# エラー追跡(任意。未設定なら無効)
SENTRY_DSN=

# キャッシュ / ジョブ(Redis)
REDIS_URL=redis://localhost:6379

# 通知(任意)
SLACK_WEBHOOK_URL=
# Slack Web API(スレッド返信・受信を使う場合。通知だけなら Webhook で足りる)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Notion(連携先のページ/DBをインテグレーションに共有しておくこと)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# 暗号化(必須: 十分に長くランダムな秘密鍵)
SESSION_SECRET=
CSRF_SECRET=
ENCRYPTION_SECRET=

# 全文検索(Meilisearch。使う場合)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# 外部連携(使うものだけ設定。OAuthトークンの取得・更新はアプリ側で行う)
LINE_CHANNEL_ACCESS_TOKEN=
FREEE_ACCESS_TOKEN=
GOOGLE_ACCESS_TOKEN=
# Microsoft 365 / Entra ID(テナントは必ず自社の ID。common は他社アカウントも通る)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REFRESH_TOKEN=

ZOHO_API_DOMAIN=https://www.zohoapis.jp
ZOHO_ACCESS_TOKEN=

# 決済(Stripe / PayPal)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
# AI(社内資料アシスタント等。@platform/ai のゲートウェイ経由でのみ使う)
ANTHROPIC_API_KEY=

# Google Maps(Sheets/Calendar はアクセストークン、Maps は API キー)
GOOGLE_MAPS_API_KEY=
