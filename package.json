{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "advisor": "node tools/advisor.mjs",
    "apps": "pnpm -r --filter './apps/*' exec node -e \"console.log(process.env.npm_package_name)\"",
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "pnpm typecheck && pnpm lint && pnpm smoke",
    "check:api": "node tools/api-surface.mjs",
    "check:build": "node tools/check-build-ready.mjs",
    "check:deps": "node tools/check-deps.mjs",
    "check:showcase": "node tools/check-showcase-deps.mjs",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules && rm -rf node_modules",
    "clean:build": "pnpm -r exec rm -rf dist .next .turbo",
    "db": "node tools/db.mjs",
    "db:down": "docker compose stop db mailhog",
    "db:psql": "docker compose exec db psql -U app -d app",
    "db:reset": "pnpm db:down && pnpm db:up",
    "db:up": "docker compose up -d db mailhog",
    "deps:why": "pnpm why",
    "dev": "turbo run dev",
    "dev:crud": "pnpm --filter crud-template dev",
    "dev:demos": "pnpm --filter showcase-demo dev",
    "dev:equipment": "pnpm --filter equipment-app dev",
    "dev:internal": "pnpm --filter internal-app dev",
    "dev:portal": "pnpm --filter platform-portal dev",
    "dev:site": "pnpm --filter public-site dev",
    "docs:apps": "echo \"アプリ側ドキュメントは docs/apps/ を参照\"",
    "docs:platform": "typedoc",
    "doctor": "node tools/doctor.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "fresh": "pnpm clean && pnpm install",
    "gen:all": "node tools/gen-all.mjs",
    "gen:appmap": "node tools/gen-app-map.mjs",
    "gen:depgraph": "node tools/gen-depgraph.mjs",
    "gen:erd": "node tools/gen-erd.mjs",
    "gen:reference": "node tools/gen-reference.mjs",
    "gen:portal-reference": "node tools/gen-portal-reference.mjs",
    "gen:site": "node tools/gen-ref-site.mjs",
    "i18n:check": "node tools/i18n-check.mjs",
    "lint": "turbo run lint",
    "loadtest": "node --experimental-strip-types tools/loadtest.mjs",
    "mcp": "pnpm --filter internal-app mcp",
    "mcp:catalog": "node --experimental-strip-types tools/mcp-catalog.mts",
    "outdated": "pnpm -r outdated || true",
    "platform:check": "node tools/platform-sync.mjs",
    "platform:sync": "node tools/platform-sync.mjs --apply",
    "scaffold": "node tools/scaffold.mjs",
    "setup": "bash scripts/setup.sh",
    "site": "pnpm gen:site && node -e \"console.log('docs/site/index.html をブラウザで開いてください')\"",
    "smoke": "node --experimental-strip-types tools/smoke.mjs",
    "test": "turbo run test",
    "test:pkg": "pnpm --filter",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm check:deps && pnpm check:api && pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "verify:offline": "node tools/preflight.mjs && node tools/check-generated.mjs",
    "version-packages": "changeset version",
    "ws:demo": "node tools/ws-demo-server.mjs",
    "gen:docs-index": "node --experimental-strip-types tools/gen-docs-index.mts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typedoc": "^0.27.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "ws": "^8.18.0"
  }
}
