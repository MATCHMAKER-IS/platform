{
  "name": "platform",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.yml"],
  "service": "workspace",
  "runServices": ["db", "mailhog"],
  "workspaceFolder": "/workspaces/platform",
  "forwardPorts": [3000, 3001, 3002, 3003, 3004, 5432, 8025],
  "portsAttributes": {
    "8025": { "label": "Mailpit (メール確認UI)" },
    "3002": { "label": "crud-template" },
    "3003": { "label": "equipment-app" }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
