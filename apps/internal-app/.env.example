# internal-app の環境変数。このファイルを .env にコピーして使う(.env は git 管理外)。
# setup.sh が未作成なら自動コピーする。

# --- 必須 ---
DATABASE_URL=postgresql://app:app@localhost:5432/app
MAIL_FROM=no-reply@example.com
SESSION_SECRET=dev-session-secret-change-me

# --- 任意(既定値あり) ---
LOG_LEVEL=info

# --- AI Gateway(@platform/ai)。未設定ならモックで動作(要約はダミー) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=            # RAG のベクトル埋め込み(@platform/ai createOpenAiEmbedder)に使う場合
SMTP_HOST=localhost
SMTP_PORT=1025
# 永続化: 未設定=インメモリ(すぐ動く・再起動で消える) / prisma=PostgreSQL(本番同等)
# CHAT_PERSISTENCE=prisma

# --- 運用系(使う機能に応じて) ---
# CRON_TOKEN=change-me                 # cron 系 API の X-Cron-Token
# SECRET_MASTER_KEY=                   # 秘密情報ストアの暗号鍵(未設定は SESSION_SECRET を流用)
# PREVIEW_TOKEN=change-me              # CMS プレビュー(public-site と同じ値)
# INQUIRY_INTAKE_TOKEN=change-me       # 公開サイトからの問い合わせ受付(public-site と同じ値)
# PUBLIC_SITE_URL=http://localhost:3004
# PUBLIC_UPLOADS_URL=
# MAINTENANCE_ALLOW_IPS=
# MAINTENANCE_BYPASS_TOKEN=
# DISABLE_NOTIFY_RELAY=1
# IDLE_TIMEOUT_MINUTES=30
# SENTRY_DSN=

# --- 認可・セッションの調整(既定値あり) ---
# SESSION_TTL_SEC=28800                # セッション有効秒数
# ALLOWED_EMAIL_DOMAINS=example.co.jp  # ログイン許可ドメイン(カンマ区切り)
# DEFAULT_ROLES=member                 # 新規ユーザーの既定ロール
# ROLE_MAP=                            # メール→ロールの割当(例: boss@example.co.jp:admin)

# --- MCP サーバ(pnpm --filter internal-app mcp)---
# MCP_ENABLE_WRITES=0                  # 1 で書き込みツール(invoice_record_payment/cancel)を有効化
# MCP_API_KEY_SCOPES=invoice:read      # 許可スコープ(invoice:read,invoice:write)

# --- Zoho 連携 / MCP の zoho_* ツールを使うとき(Self Client で発行) ---
# ZOHO_DC=jp
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# --- Zoho SSO(「Zoho でログイン」を使うとき) ---
# ZOHO_REDIRECT_URI=http://localhost:3000/api/auth/zoho/callback
# ZOHO_SCOPE=

# --- Platform Debugger(開発時のみ) ---
# true にすると /debug でリクエストの中身(SQL・AI・所要時間)を確認できる。
# 本番(NODE_ENV=production)では設定しても強制的に無効になる。
# DEBUG_TOOL=true

# --- システムアラートの通知先(任意。未設定ならログのみ) ---
# ALERT_MAIL_TO=ops@example.com
# ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx

# タスクの永続化。prisma で DB に保存(未設定ならメモリ=再起動で消える)
# TASK_PERSISTENCE=prisma

# FAQ・契約の永続化。prisma で DB に保存(未設定ならメモリ=再起動で消える)
# FAQ_PERSISTENCE=prisma
# CONTRACT_PERSISTENCE=prisma
