# public-site の環境変数(任意。未設定でも起動する)。使う機能に応じて .env へコピーして設定。
# INTERNAL_API_BASE=http://localhost:3000              # internal-app の API(CMS 記事などの取得元)
# INTERNAL_INQUIRY_URL=http://localhost:3000/api/inquiries/intake
# INQUIRY_INTAKE_TOKEN=change-me                       # internal-app 側と同じ値にする
# PREVIEW_TOKEN=change-me                              # internal-app 側と同じ値にする
