{
  "name": "@platform/session",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./idle-timer": {
      "types": "./dist/idle-timer.d.ts",
      "default": "./dist/idle-timer.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@platform/core": "workspace:*",
    "@platform/crypto": "workspace:*"
  },
  "devDependencies": {
    "@platform/config": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
