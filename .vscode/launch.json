{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: 現在のテストファイル (Vitest)",
      "type": "node",
      "request": "launch",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug: 全テスト (Vitest)",
      "type": "node",
      "request": "launch",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug: スモークテスト",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--experimental-strip-types"],
      "program": "${workspaceFolder}/tools/smoke.mjs",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug: Next.js (server-side)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/internal-app",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "serverReadyAction": { "pattern": "- Local:.+(https?://.+)", "uriFormat": "%s", "action": "debugWithChrome" }
    },
    {
      "name": "Attach: 実行中の Node (--inspect)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
